# DJZS + Irys Starter

# EVM private key used to pay Irys for uploads.
# Use a test wallet, NEVER your main production wallet.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: RPC URL if you decide to use devnet.
# For mainnet ETH you can usually omit this and just use withWallet().
RPC_URL=https://your-rpc-url.example
